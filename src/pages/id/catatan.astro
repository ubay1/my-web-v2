---
import { changeLanguage } from 'i18next'
import Notes from '@components/pages/Notes'
import BaseLayout from '@layouts/BaseLayout.astro'
import { sortByDate } from '@utils/sortByDate'
import type { IBlogDetail } from '@typess/blog'

changeLanguage('id')

const allBlogs = await Astro.glob('./catatan/*.md')
const pageTitle = 'Catatan'
---

<BaseLayout pageTitle={pageTitle}>
  <div class="max-w-3xl mt-10 mb-4">
    <div class="gap-4 space-y-4 p-2 columns-1 md:columns-2">
      {allBlogs.sort(sortByDate).map((post) => <Notes client:load data={post as IBlogDetail} />)}
    </div>
  </div>
</BaseLayout>
